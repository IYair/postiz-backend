LISTMONK_LIST_ID=""
LISTMONK_WELCOME_TEMPLATE_ID=""
THREADS_APP_ID=""
THREADS_APP_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_PIXEL_ACCESS_TOKEN=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
DRIBBBLE_CLIENT_ID=""
DRIBBBLE_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN_ID=""
SLACK_ID=""
SLACK_SECRET=""
SLACK_SIGNING_SECRET=""
MASTODON_URL="https://mastodon.social"
MASTODON_CLIENT_ID=""
MASTODON_CLIENT_SECRET=""
TELEGRAM_TOKEN=""
TELEGRAM_BOT_NAME=""
KICK_CLIENT_ID=""
KICK_SECRET=""
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
# Farcaster via Neynar
NEYNAR_CLIENT_ID=""
NEYNAR_SECRET_KEY=""
NEYNAR_LOGIN_URL=""
# MeWe
MEWE_API_KEY=""
MEWE_APP_ID=""
MEWE_HOST=""
# VKontakte
VK_ID=""
# Whop
WHOP_CLIENT_ID=""
# Google My Business
GOOGLE_GMB_CLIENT_ID=""
GOOGLE_GMB_CLIENT_SECRET=""

# Chrome Extension Settings (for cookie-based platform integrations like Skool)
EXTENSION_ID=""

# === AI Providers (Multi-provider: Anthropic Claude / OpenAI / Google Gemini)
#
# NOTE: User-level AI API keys (Anthropic, OpenAI, Gemini) are NOT read from env.
# They are configured per-user via the UI (Settings > AI Providers) and stored
# ENCRYPTED in the database using ENCRYPTION_KEY defined above.
#
# The OPENAI_API_KEY below is ONLY a legacy fallback used by the agent tool loader
# (libs/nestjs-libraries/src/chat/load.tools.service.ts) when no user config exists.
# Leave empty in production; configure per-user keys through the UI instead.
OPENAI_API_KEY=""
# OPENAI_APP_CHALLANGE=""   # Used by OpenAI app webhook verification (MCP start flow)

# === MCP (Model Context Protocol) server
# MCP_URL=""                 # Public URL for the Postiz MCP server, used by AI agents

# === Extra AI / media services (optional)
# TAVILY_API_KEY=""          # Tavily web-search tool used by the agent
# FAL_KEY=""                 # Fal.ai image generation
# ELEVENSLABS_API_KEY=""     # ElevenLabs text-to-speech
# KIEAI_API_KEY=""           # KieAI service
# DATAFAST_API_KEY=""        # DataFast analytics
# DATAFAST_WEBSITE_ID=""
# TRANSLOADIT_AUTH=""        # Media processing via Transloadit
# TRANSLOADIT_SECRET=""
# TRANSLOADIT_TEMPLATE=""

# Misc Settings
NEXT_PUBLIC_DISCORD_SUPPORT=""
NEXT_PUBLIC_POLOTNO=""
# NOT_SECURED=false
API_LIMIT=30 # The limit of the public API hour limit
# RUN_CRON=true                      # Enable cron job runner in this process
# DISABLE_IMAGE_COMPRESSION=false    # Skip server-side image compression
# DISABLE_X_ANALYTICS=false          # Disable X (Twitter) analytics polling
# RESTRICT_UPLOAD_DOMAINS=""         # Comma-separated allow-list of upload source domains
# AGENT_API_KEY=""                   # Key for agent-to-agent API calls
# AGENT_MEDIA_SSO_KEY=""             # SSO key for agent media access
# NEXT_PUBLIC_APP_VERSION=""         # App version string (shown in UI)

# Payment settings
FEE_AMOUNT=0.05
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_SIGNING_KEY=""
STRIPE_SIGNING_KEY_CONNECT=""
# STRIPE_DISCOUNT_ID=""         # Default discount code applied to checkout
# NOWPAYMENTS_API_KEY=""        # Crypto payments via NOWPayments
# NOWPAYMENTS_AMOUNT=""

# === Temporal (background jobs / orchestrator)
# TEMPORAL_ADDRESS="localhost:7233"
# TEMPORAL_TLS=false
# TEMPORAL_API_KEY=""
# TEMPORAL_NAMESPACE="default"

# === Telemetry & Monitoring (optional)
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_ENVIRONMENT=""
# SENTRY_RELEASE=""
# SENTRY_DEBUG=false
# SENTRY_SPOTLIGHT=false
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# Developer Settings
NX_ADD_PLUGINS=false
IS_GENERAL="true" # required for now
NEXT_PUBLIC_POSTIZ_OAUTH_DISPLAY_NAME="Authentik"
NEXT_PUBLIC_POSTIZ_OAUTH_LOGO_URL="https://raw.githubusercontent.com/walkxcode/dashboard-icons/master/png/authentik.png"
POSTIZ_GENERIC_OAUTH="false"
POSTIZ_OAUTH_URL="https://auth.example.com"
POSTIZ_OAUTH_AUTH_URL="https://auth.example.com/application/o/authorize"
POSTIZ_OAUTH_TOKEN_URL="https://auth.example.com/application/o/token"
POSTIZ_OAUTH_USERINFO_URL="https://authentik.example.com/application/o/userinfo"
POSTIZ_OAUTH_CLIENT_ID=""
POSTIZ_OAUTH_CLIENT_SECRET=""
# POSTIZ_OAUTH_SCOPE="openid profile email" # default values

